ANTHROPIC_API_KEY=your_key_here
ELEVENLABS_API_KEY=your_key_here

# Default (English) voices
ELEVENLABS_VOICE_ID_ARIA=voice_id_here
ELEVENLABS_VOICE_ID_REX=voice_id_here

# Optional per-language voices. If unset, the English voices are used.
# German:
# ELEVENLABS_VOICE_ID_ARIA_DE=voice_id_here
# ELEVENLABS_VOICE_ID_REX_DE=voice_id_here

# Persian (Farsi) text-to-speech — ElevenLabs has no native Farsi voice, so
# Persian debates route to Azure Speech instead (see backend/azure.js and
# backend/tts.js). Get these from an Azure "Speech" resource in the Azure
# portal (Keys and Endpoint page). Free tier: 500,000 characters/month.
# AZURE_SPEECH_KEY=your_key_here
# AZURE_SPEECH_REGION=eastus
# Optional overrides — defaults are Azure's two native fa-IR neural voices:
# AZURE_VOICE_ID_ARIA_FA=fa-IR-DilaraNeural
# AZURE_VOICE_ID_REX_FA=fa-IR-FaridNeural

# Optional: cap how many debates can start per UTC day (default 30)
# DAILY_DEBATE_LIMIT=30

PORT=3000
