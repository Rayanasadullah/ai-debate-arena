ANTHROPIC_API_KEY=your_key_here
ELEVENLABS_API_KEY=your_key_here

# Default (English) voices
ELEVENLABS_VOICE_ID_ARIA=voice_id_here
ELEVENLABS_VOICE_ID_REX=voice_id_here

# Optional per-language voices. If unset, the English voices are used.
# German:
# ELEVENLABS_VOICE_ID_ARIA_DE=voice_id_here
# ELEVENLABS_VOICE_ID_REX_DE=voice_id_here
# Persian (Farsi) — routes through ElevenLabs' eleven_v3 model (see
# elevenlabs.js MODEL_BY_LANG). If unset, the English voices above are reused
# for Persian too (v3 can speak Persian in any voice); set these only if you
# want Delaram/Mirza to sound different from the English Nova/Umbra voices:
# ELEVENLABS_VOICE_ID_ARIA_FA=voice_id_here
# ELEVENLABS_VOICE_ID_REX_FA=voice_id_here

# No longer used for Persian voice (moved to ElevenLabs above — Azure's
# entire fa-IR catalog was only 2 fixed, robotic voices). backend/azure.js
# and backend/tts.js's Azure import were left in place, unused, in case
# Persian TTS ever needs to fall back to Azure again:
# AZURE_SPEECH_KEY=your_key_here
# AZURE_SPEECH_REGION=eastus
# AZURE_VOICE_ID_ARIA_FA=fa-IR-DilaraNeural
# AZURE_VOICE_ID_REX_FA=fa-IR-FaridNeural

# Optional: cap how many debates can start per UTC day, site-wide (default 30)
# DAILY_DEBATE_LIMIT=30
# Optional: cap how many debates a single signed-in person can start per UTC day
# DAILY_DEBATE_LIMIT_PER_USER=5
# Optional: comma-separated emails exempt from the per-person daily limit
# UNLIMITED_EMAILS=you@example.com,friend@example.com

# Accounts, cross-device history, and the admin allowlist — all optional.
# Omit these to run with "Continue without an account" only (local storage,
# no cross-device sync, no admin panel). Requires a Supabase project; the
# frontend's matching SUPABASE_URL/SUPABASE_ANON_KEY are NOT env vars — they're
# set directly in frontend/index.html (see README).
# SUPABASE_SERVICE_ROLE_KEY=your_key_here
# ADMIN_EMAIL=you@example.com   # this email gets the admin panel + unlimited debates

# Feedback form (Options drawer) — optional. Without these, feedback
# submissions fail silently on the backend; the form itself still renders.
# RESEND_API_KEY=your_key_here
# FEEDBACK_TO_EMAIL=you@example.com

# CORS: your deployed frontend's origin (required in production; not needed
# for localhost-only development)
# FRONTEND_ORIGIN=https://your-app.netlify.app

PORT=3000
