ANTHROPIC_API_KEY=your_key_here
ELEVENLABS_API_KEY=your_key_here

# Default (English) voices
ELEVENLABS_VOICE_ID_ARIA=voice_id_here
ELEVENLABS_VOICE_ID_REX=voice_id_here

# Optional per-language voices. If unset, the English voices are used.
# German:
# ELEVENLABS_VOICE_ID_ARIA_DE=voice_id_here
# ELEVENLABS_VOICE_ID_REX_DE=voice_id_here

# Optional: cap how many debates can start per UTC day (default 30)
# DAILY_DEBATE_LIMIT=30

PORT=3000
